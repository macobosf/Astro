---
// Importa el componente RecursoCard desde la carpeta de componentes compartidos
import RecursoCard from '../components/RecursoCard.astro';

const titulo = "Acerca de Astro Campus";
const descripcion =
  "Proyecto incremental para aprender Astro en el contexto del curso PPW.";
const equipo = [{ nombre: "Pablo Torres", rol: "Docente", github: "PabloT18" }];
const modoProduccion = import.meta.env.PROD;

// Catálogo de herramientas recomendadas para el aprendizaje de Astro
const herramientas = [
  {
    titulo: "Documentación oficial de Astro",
    url: "https://docs.astro.build",
    descripcion: "Guía completa y referencia de la API de Astro.",
  },
  {
    titulo: "MDN Web Docs",
    url: "https://developer.mozilla.org",
    descripcion: "Referencia esencial de HTML, CSS y JavaScript.",
  },
  {
    titulo: "VS Code",
    url: "https://code.visualstudio.com",
    descripcion: "Editor recomendado con soporte oficial para Astro.",
  },
];

// Bandera que indica si existe al menos una herramienta para mostrar
const mostrarHerramientas = herramientas.length > 0;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo}</title>
  </head>
  <body>
    <main>
      <h1>{titulo}</h1>
      <p>{descripcion}</p>

      <h2>Equipo</h2>
      <ul>
        {
          equipo.map((p) => (
            <li>
              <strong>{p.nombre}</strong> — {p.rol}
              {" · "}
              <a
                href={`https://github.com/${p.github}`}
                target="_blank"
                rel="noopener"
              >
                GitHub
              </a>
            </li>
          ))
        }
      </ul>

      <section>
        <h2>Herramientas</h2>

        {/* Renderiza la lista solo cuando el arreglo tiene elementos */}
        {mostrarHerramientas && (
          <div>
            {/* Genera un RecursoCard por cada herramienta del catálogo */}
            {herramientas.map((herramienta) => (
              <RecursoCard
                titulo={herramienta.titulo}
                url={herramienta.url}
                descripcion={herramienta.descripcion}
              />
            ))}
          </div>
        )}

        {/* Mensaje de respaldo cuando no hay herramientas registradas */}
        {!mostrarHerramientas && <p>No hay herramientas disponibles.</p>}
      </section>

      <nav>
        <a href="/">← Inicio</a>
      </nav>

      {
        modoProduccion && (
          <p style="color: #22c55e; font-size: 0.8rem;">
            Versión de producción activa.
          </p>
        )
      }
      {
        !modoProduccion && (
          <p style="color: #f59e0b; font-size: 0.8rem;">
            Modo desarrollo — usa <code>pnpm build</code> para producción.
          </p>
        )
      }
    </main>
  </body>
</html>

<style is:global>
  body {
    font-family: system-ui, sans-serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    background: #0f0f0f;
    color: #e8e8e8;
  }
  h1 {
    color: #ff5d01;
  }
  a {
    color: #ff5d01;
  }
  li {
    margin-bottom: 0.5rem;
  }
</style>
